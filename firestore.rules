rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validations
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().uid == userId;
      allow update: if isOwner(userId) && incoming().uid == userId && (
        // Prevent self-assigned admin roles
        (!incoming().keys().hasAll(['role']) || existing().role == incoming().role || isAdmin())
      ) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Admins collection (used for fast admin lookups)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 2. Courses
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3. Enrolled Courses
    match /enrolledCourses/{enrollmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 4. Interview Questions
    match /interview_questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 5. Mock Interviews
    match /mock_interviews/{interviewId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 6. Resumes
    match /resumes/{resumeId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 7. Notes
    match /notes/{noteId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 8. Quizzes
    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 9. Quiz Results
    match /quiz_results/{resultId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 10. Learning Paths
    match /learning_paths/{pathId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 11. Progress
    match /progress/{progressId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || incoming().uid == request.auth.uid);
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || existing().uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 12. Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 13. Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 14. Support Messages
    match /support_messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 15. Feedback
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 16. Certificates
    match /certificates/{certificateId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 17. Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // 18. Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
